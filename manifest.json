{
  "manifest_version": 3,
  "name": "SAM Table Filter",
  "version": "1.1.1",
  "description": "Lists every SAM Table recommendation and lets you filter by action (Continue Buying, Hold, Stop Buying...), category, and search.",
  "browser_specific_settings": {
    "gecko": {
      "id": "sam-table-filter@trc.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://members.trulyrichclub.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SAM Table Filter"
  },
  "content_scripts": [
    {
      "matches": ["https://members.trulyrichclub.com/member/recommendations/sam*"],
      "js": ["parser.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
